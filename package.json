{
  "name": "code-review-agent",
  "version": "0.1.0",
  "description": "Privacy-first GitHub Action for automated code review using local LLMs.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && ncc build -o dist src/index.ts",
    "test": "tsx --test dist-tests/*.test.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": [
    "github-action",
    "code-review",
    "llm",
    "ollama",
    "privacy",
    "ai"
  ],
  "author": "fuleinist",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.0",
    "@actions/glob": "^0.7.0",
    "openai": "^4.71.0"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "@vercel/ncc": "^0.38.3",
    "tsx": "^4.23.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
